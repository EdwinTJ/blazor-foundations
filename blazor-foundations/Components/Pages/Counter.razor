@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<div class="counter-container">
    <p class="counter-value">Current Count: @currentCount</p>
    <div class="button-group">
        <button @onclick="Increment">Increment</button>
        <button @onclick="Decrement">Decrement</button>
        <button @onclick="Reset">Reset</button>
    </div>
</div>


@code{
    private int currentCount = 0;

    private void Increment()
    {
        currentCount++;
    }

    private void Decrement()
    {
        currentCount--;
    }

    private void Reset()
    {
        currentCount = 0;
    }
}

<style>
    .counter-container {
        padding: 20px;
        max-width: 400px;
    }

    .counter-value {
        font-size: 20px;
        margin-bottom: 10px;
    }

    .button-group button {
        margin-right: 8px;
        padding: 8px 12px;
        cursor: pointer;
    }
</style>